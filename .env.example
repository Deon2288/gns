# Environment Variables Template

# Node Environment
NODE_ENV=development

# Database URL
DATABASE_URL=postgres://user:password@localhost:5432/mydb

# JWT Secret
JWT_SECRET=your_jwt_secret

# Redis URL
REDIS_URL=redis://localhost:6379

# Sentry DSN
SENTRY_DSN=https://your-sentry-dsn

# API Keys
API_KEY_SERVICE1=your_api_key_for_service1
API_KEY_SERVICE2=your_api_key_for_service2

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=your_region

# OTA Firmware Update Configuration
FIRMWARE_STORAGE_PATH=./uploads/firmware

# MQTT Configuration (optional - for device communication)
# MQTT_BROKER_URL=mqtts://your-broker:8883
# MQTT_USERNAME=your_mqtt_user
# MQTT_PASSWORD=your_mqtt_password

# Frontend API URL (set in frontend .env)
# REACT_APP_API_URL=http://localhost:3000
# REACT_APP_WS_URL=ws://localhost:3000