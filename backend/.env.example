# Copy this file to backend/.env and fill in your values.
# Never commit .env – it is listed in .gitignore.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gns
DB_USER=gns_user
DB_PASSWORD=change_me

# ── Authentication ───────────────────────────────────────────────────────────
# Generate a strong random secret, e.g.:  openssl rand -hex 64
JWT_SECRET=change_me_to_a_long_random_string

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
WEBSOCKET_PORT=8080
