# Copy this file to frontend/.env.local and fill in your values.
# Never commit .env.local – it is listed in .gitignore.

# Mapbox public access token
# Get your token at https://account.mapbox.com/access-tokens/
REACT_APP_MAPBOX_TOKEN=your_mapbox_public_token_here

# WebSocket server URL (defaults to ws://localhost:8080 if not set)
REACT_APP_WS_URL=ws://localhost:8080
